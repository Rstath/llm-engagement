# Backend secrets/settings for Render or local testing
APP_SECRET=change-this-to-a-long-random-secret
RESEARCHER_PASSWORD=change-this-password
DB_PATH=human_experiment_data.db

# Put your final GitHub Pages URL here after frontend deploy
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://YOUR_GITHUB_USERNAME.github.io

# Hosted LLM endpoint - OpenRouter is OpenAI-compatible
LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=your_openrouter_api_key_here
OPENROUTER_SITE_URL=https://YOUR_GITHUB_USERNAME.github.io/YOUR_REPO_NAME/
OPENROUTER_APP_NAME=LLM Engagement Study

# Experiment model conditions
# Small condition: E4B-class Gemma. OpenRouter currently lists Gemma 3n E4B; if Gemma 4 E4B appears, replace only this value.
SMALL_LLM_MODEL=google/gemma-3n-e4b-it
# Medium condition: Gemma 4 31B free variant on OpenRouter
MEDIUM_LLM_MODEL=google/gemma-4-31b-it:free

DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_AGENT_TOKENS=130
TARGET_TOTAL_TURNS=14
